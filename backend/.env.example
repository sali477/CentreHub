NODE_ENV=development
# Set to true to disable API rate limits (useful if login returns 429 during local dev)
RATE_LIMIT_DISABLED=false
PORT=5000
MONGODB_URI=mongodb://localhost:27017/centrehub_morocco
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Google OAuth — same Client ID as frontend VITE_GOOGLE_CLIENT_ID
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary (optional — leave empty to use local disk storage in development)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@centrehub.ma
FROM_NAME=CentreHub Morocco

# Groq — powers the AI chat assistant (https://console.groq.com/keys)
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend URL (for CORS & email links)
CLIENT_URL=http://localhost:5173

# Jitsi Meet — public instance or your self-hosted domain
JITSI_BASE_URL=https://meet.jit.si

# Google Maps (used by frontend, documented here)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CMI (Centre Monétique Interbancaire - Morocco)
CMI_MERCHANT_ID=your_cmi_merchant_id
CMI_SECRET_KEY=your_cmi_secret_key
CMI_GATEWAY_URL=https://payment.cmi.co.ma/fim/est3Dgate
