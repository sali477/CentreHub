VITE_API_URL=/api
VITE_SOCKET_URL=http://127.0.0.1:5000
VITE_PROXY_TARGET=http://127.0.0.1:5000
# Google OAuth — required for "Sign in with Google"
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized JavaScript origins: http://localhost:5173
# 4. Copy Client ID to BOTH lines below (frontend + backend)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Google Maps (optional — map uses OpenStreetMap when this is not set)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Optional: Google Cloud Map ID (only if you use styled maps)
# VITE_GOOGLE_MAP_ID=

# Stripe (optional — publishable key for future embedded checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Jitsi Meet domain (default: meet.jit.si)
VITE_JITSI_DOMAIN=meet.jit.si
